fun cekPembuat(name){
    if (name == "Hafidh") {
        println("Kamu Pembuat bahasa ini!")
    } else if (name == "Hafidh Musyaffa") {
        println("Kamu Pembuat bahasa ini! (nama lengkap)")
    } else {
        println("Aku ga kenal kamu.")
    }
}

println("=" * 20);
let name = readline("Masukan nama: ");
println("=" * 20);
cekPembuat(name)
println("=" * 20);
